# Root
賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭*/
@import url("../../../css/root.css");
/*賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭
# Best Deals
賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭*/
.BestDeals {
  position: relative;
  width: 100%;
  background-color: var(--white-alt-1);
  padding-top: var(--main-padding-top);
  padding-bottom: var(--main-padding-bottom);
}
.BestDeals h1 {
  font-family: "Darumadrop One", cursive;
  font-weight: 700;
  margin-bottom: 30px;
}
.BestDeals .card {
  position: relative;
  width: 100%;
  cursor: crosshair;
}
.BestDeals .card .header {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: var(--main-border-radius);
  overflow: hidden;
  background-color: #fff;
}
.BestDeals .card .header img {
  position: relative;
  width: 250px;
  height: 250px;
  transition: var(--main-transition);
}
.BestDeals .card:hover img {
  transform: scale(1.3);
}
.BestDeals .card .header i {
  position: absolute;
  top: 15px;
  right: 15px;
  font-size: 18px;
  cursor: pointer;
  background-color: #fff;
}
.BestDeals .card .header i:hover {
  color: #ff0000;
  fill: #ff0000;
}
.BestDeals .card .footer {
  position: relative;
  padding: 10px 0;
}
.BestDeals .card .footer .info {
  position: relative;
  background-color: transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.BestDeals .card .footer .info span {
  position: relative;
  font-size: 18px;
  font-weight: bold;
}
.BestDeals .card .footer .info span.Price {
  position: relative;
  padding: 0 25px 0 15px;
  font-weight: bold;
  width: fit-content;
}
.BestDeals .card .footer .info span.Price::before {
  content: " .00";
  position: absolute;
  top: -1px;
  right: 5px;
  font-size: 14px;
  font-weight: normal;
}
.BestDeals .card .footer .info span.Price::after {
  position: absolute;
  content: "";
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  content: "\24";
  top: -1px;
  left: 0px;
  font-size: 14px;
  font-weight: normal;
}
.BestDeals .card .footer p {
  position: relative;
  font-size: 14px;
  margin: 10px 0;
}
.BestDeals .card .footer .stars {
  position: relative;
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  gap: 2px;
  margin: 10px 0;
}
.BestDeals .card .footer .stars i {
  color: #47c20a;
}
.BestDeals .card .footer button {
  position: relative;
  border-radius: calc(var(--main-border-radius) * 5);
  padding: 8px 15px;
  border: 0.5px solid #888;
  cursor: pointer;
  transition: var(--main-transition);
  background-color: transparent;
}
.BestDeals .card .footer button:hover {
  background-color: #47c20a;
  border: 0.5px solid #47c20a;
  color: #fff;
}
.BestDeals .progress {
  position: relative;
  width: 100%;
  height: 10px;
  background-color: #fff;
  border-radius: var(--main-border-radius);
  overflow: hidden;
  transition: var(--main-transition);
  margin: 10px 0;
}
.BestDeals .progress .propress-per {
  position: absolute;
  top: 0;
  left: 0;
  transition: var(--main-transition);
  background-color: var(--blue-color);
  height: 100%;
}
