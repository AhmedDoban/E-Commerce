# Root
賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭*/
@import url("../../../css/root.css");
/*賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭
# Cash Back
賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭賭*/
.CashBack {
  position: relative;
  width: 100%;
  height: 70vh;
  background-color: #000;
  padding: 100px;
  display: flex;
  overflow: hidden;
}
.CashBack .backgroud-img {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  object-fit: cover;
  object-position: bottom center;
  transform: scale(1);
  transition: var(--main-transition);
}
.CashBack .container {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.CashBack .container .card {
  position: relative;
  width: 500px;
  height: 450px;
  background-color: #003d29;
  padding: 50px;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  flex-direction: column;
  gap: 15px;
  transition: var(--main-transition);
}
.CashBack .container .card h1 {
  position: relative;
  font-size: 55px;
  color: var(--white-color);
  text-align: left;
}
.CashBack .container .card p {
  color: var(--white-color);
  font-size: 20px;
  line-height: 1.7;
}
.CashBack .container .card a {
  position: relative;
  padding: 15px 30px;
  border: 1px solid var(--white-color);
  border-radius: calc(var(--main-border-radius) * 5);
  color: var(--white-color);
  cursor: pointer;
  transition: var(--main-transition);
}
.CashBack .container .card a:hover {
  background-color: #333;
  border: 1px solid #333;
}
@media (max-width: 992px) {
  .CashBack {
    height: 50vh;
    padding: 50px 10px;
  }
  .CashBack .container .card {
    width: 100%;
    height: 100%;
  }
  .CashBack .container .card h1 {
    font-size: 35px;
  }
  .CashBack .container .card p {
    font-size: 16px;
  }
}
